<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.WithdrawalRequestMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.entity.WithdrawalRequest">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="tournament_id" property="tournamentId" />
        <result column="reason" property="reason" />
        <result column="status" property="status" />
        <result column="processed_by" property="processedBy" />
        <result column="processed_at" property="processedAt" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, user_id, tournament_id, reason, status, processed_by, processed_at, created_at, updated_at
    </sql>

</mapper>
